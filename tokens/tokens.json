{
  "$description": "Taeyang Han design tokens. Mirrors tokens.css (the canonical source, synced from the portfolio). Hex values are light mode; dark mode overrides under color.semantic.*.dark.",
  "color": {
    "brand": {
      "sunshine": { "value": "#FFD859", "use": "Primary accent, badges, panel headers, highlights" },
      "coral":    { "value": "#FF6B6B", "use": "Alerts, focus rings, energetic CTAs, in-development" },
      "sky":      { "value": "#6EC6FF", "use": "Info, cool accents" },
      "mint":     { "value": "#7EE6A7", "use": "Success, active/completed status" },
      "purple":   { "value": "#B084F5", "use": "Special / creative accents" },
      "ink":      { "value": "#1E1E1E", "use": "Text, borders, shadows, dark fills" },
      "greyDark":  { "value": "#555555", "use": "Secondary text" },
      "greyLight": { "value": "#DCDCDC", "use": "Subtle borders, tracks, dividers" },
      "cream":    { "value": "#FFF7E6", "use": "Page background (the notebook page)" }
    },
    "brandDark": {
      "sunshine": "#D4A800",
      "coral":    "#E05555",
      "sky":      "#5AAEE0",
      "mint":     "#5DC985",
      "purple":   "#9B6FE0"
    },
    "semantic": {
      "bgPrimary":     { "light": "#FFF7E6", "dark": "#1A1917" },
      "bgPanel":       { "light": "#FFFFFF", "dark": "#242220" },
      "textPrimary":   { "light": "#1E1E1E", "dark": "#E8E6E0" },
      "textSecondary": { "light": "#555555", "dark": "#A8A29E" },
      "textMuted":     { "light": "#9CA3AF", "dark": "#6B6760" },
      "textOnDark":    { "light": "#FFFFFF", "dark": "#E8E6E0" },
      "borderMain":    { "light": "#1E1E1E", "dark": "#E8E6E0" },
      "borderLight":   { "light": "#DCDCDC", "dark": "#3A3835" },
      "surfaceInvert": { "light": "#1E1E1E", "dark": "#100F0E", "note": "Stays dark in both themes (footer/manifesto band)" }
    },
    "textOnFill": {
      "note": "Coral & Purple fills use white text. Sunshine, Sky & Mint fills use ink text. Never grey on a colored fill."
    }
  },
  "typography": {
    "fontFamily": {
      "body":  "'Inter', system-ui, -apple-system, 'Noto Sans KR', sans-serif",
      "game":  "'DM Sans', 'Noto Sans KR', system-ui, sans-serif",
      "pixel": "'Press Start 2P', 'Courier New', Courier, monospace",
      "hand":  "'Caveat', cursive"
    },
    "scale": {
      "sectionTitle": { "font": "game",  "size": "clamp(1.35rem, 3.5vw, 1.75rem)", "weight": 800, "tracking": "-0.02em", "lineHeight": 1.2 },
      "headline":     { "font": "game",  "size": "clamp(1.25rem, 3vw, 1.5rem)",    "weight": 700, "tracking": "-0.02em", "lineHeight": 1.2 },
      "panelHeader":  { "font": "game",  "size": "13px", "weight": 700 },
      "body":         { "font": "body",  "size": "16px", "weight": 400, "lineHeight": 1.6 },
      "micro":        { "font": "pixel", "size": "10px", "weight": 700, "tracking": "0.08em", "case": "uppercase", "note": "Labels and accents only — never body copy" }
    }
  },
  "space": { "xs": "4px", "sm": "8px", "md": "16px", "lg": "24px", "xl": "32px", "2xl": "48px", "3xl": "64px" },
  "radius": { "sm": "4px", "md": "8px", "lg": "12px", "pill": "999px" },
  "border": {
    "thick":  "3px solid var(--ink)",
    "thin":   "2px solid var(--ink)",
    "subtle": "2px solid var(--grey-light)"
  },
  "shadow": {
    "$note": "Hard offset, NO blur — the signature look.",
    "offset":    "4px 4px 0 var(--ink)",
    "offsetSm":  "2px 2px 0 var(--ink)",
    "pressed":   "1px 1px 0 var(--ink)"
  },
  "motion": {
    "ease": { "bounce": "cubic-bezier(0.34, 1.56, 0.64, 1)", "smooth": "cubic-bezier(0.2, 0.8, 0.2, 1)" },
    "duration": { "fast": "150ms", "medium": "250ms", "slow": "400ms" },
    "transform": { "hoverLift": "translateY(-2px)", "activePress": "translateY(1px)" }
  },
  "layout": {
    "containerMaxWidth": "1040px",
    "sectionPadding": { "desktop": "64px 24px", "mobile": "48px 16px" },
    "breakpointMobile": "768px"
  }
}
