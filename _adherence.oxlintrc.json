{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/icons/**",
              "components/core/**",
              "ui_kits/portfolio/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Caveat|DM Sans|Inter|Klee One|Nanum Pen Script|Noto Sans KR|Press Start 2P|ZCOOL KuaiLe))/i]",
        "message": "Font not provided by the design system. Available: Caveat, DM Sans, Inter, Klee One, Nanum Pen Script, Noto Sans KR, Press Start 2P, ZCOOL KuaiLe."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--active-press",
      "--bg-panel",
      "--bg-primary",
      "--border-light",
      "--border-main",
      "--border-subtle",
      "--border-thick",
      "--border-thin",
      "--container-max",
      "--coral",
      "--cream",
      "--duration-fast",
      "--duration-medium",
      "--duration-slow",
      "--ease-bounce",
      "--ease-smooth",
      "--font-body",
      "--font-game",
      "--font-hand",
      "--font-hand-ja",
      "--font-hand-ko",
      "--font-hand-zh",
      "--font-pixel",
      "--fs-body",
      "--fs-headline",
      "--fs-micro",
      "--fs-panel-header",
      "--fs-pixel-badge",
      "--fs-section-title",
      "--fs-small",
      "--grey-dark",
      "--grey-light",
      "--hover-lift",
      "--ink",
      "--lh-body",
      "--lh-tight",
      "--mint",
      "--purple",
      "--radius-lg",
      "--radius-md",
      "--radius-pill",
      "--radius-sm",
      "--shadow-none",
